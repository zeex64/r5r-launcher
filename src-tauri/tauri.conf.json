{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "R5Reloaded Launcher",
  "version": "0.1.9",
  "identifier": "com.r5reloaded.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "R5Reloaded Launcher",
        "width": 1250,
        "height": 686,
        "minWidth": 1250,
        "minHeight": 686,
        "resizable": true,
        "center": true,
        "decorations": false,
        "theme": "Dark",
        "backgroundColor": "#07080b"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
